{
  "info": {
    "_postman_id": "f5d5ce5e-41c2-4f71-8dd6-bf8751ad1a11",
    "name": "Consultas Empleados API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección para probar consultas paginadas de empleados con Basic Auth."
  },
  "item": [
    {
      "name": "Health - OpenAPI",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v3/api-docs",
          "host": ["{{baseUrl}}"],
          "path": ["v3", "api-docs"]
        }
      }
    },
    {
      "name": "Listar empleados paginados",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Tiene campos de paginación', function () {",
              "  pm.expect(json).to.have.property('content');",
              "  pm.expect(json).to.have.property('page');",
              "  pm.expect(json).to.have.property('size');",
              "  pm.expect(json).to.have.property('totalElements');",
              "  pm.expect(json).to.have.property('totalPages');",
              "});",
              "pm.test('size es 10', function () {",
              "  pm.expect(json.size).to.eql(10);",
              "});",
              "pm.test('content máximo 10', function () {",
              "  pm.expect(json.content.length).to.be.at.most(10);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{user}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{pass}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/empleados?page=0",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "empleados"],
          "query": [
            {
              "key": "page",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "Listar empleados sin credenciales (espera 401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 401', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/empleados?page=0",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "empleados"],
          "query": [
            {
              "key": "page",
              "value": "0"
            }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "user",
      "value": "admin"
    },
    {
      "key": "pass",
      "value": "admin123"
    }
  ]
}
